# ============================================================
# FinSight — Environment Variables Template
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your keys below
# 3. NEVER commit .env to git — it is in .gitignore
# ============================================================

# --- Groq API (Free LLM inference) ---
# Sign up: https://console.groq.com
# No credit card required
GROQ_API_KEY=your_groq_api_key_here

# --- Alpha Vantage (Fundamental financial data) ---
# Sign up: https://www.alphavantage.co/support/#api-key
# Free tier: 25 API calls/day
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- NewsAPI (Company news headlines) ---
# Sign up: https://newsapi.org/register
# Free tier: 100 requests/day, developer use only
NEWS_API_KEY=your_newsapi_key_here

# --- MLflow Tracking Server ---
# Local development default — change to your EC2 URL after deployment
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=finsight-runs

# --- Application Settings ---
# Directory where generated PDF reports are saved
REPORTS_DIR=data/reports
# Directory for Evidently AI reference datasets
REFERENCE_DATA_DIR=data/reference
# Groq model to use for report generation
LLM_MODEL=llama3-70b-8192
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
